          "inputs": {
            "uri": "https://login.microsoftonline.com/1d7bf184-976a-4221-bbb4-18240175ed7d/oauth2/v2.0/token",
            "method": "POST",
            "headers": {
              "Content-Type": "application/x-www-form-urlencoded"
