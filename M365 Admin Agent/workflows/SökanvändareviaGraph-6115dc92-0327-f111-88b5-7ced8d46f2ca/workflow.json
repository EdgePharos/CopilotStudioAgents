            "body": "@concat('client_id=4d9ba878-3a01-461c-825a-741d3bac0a75&scope=https://graph.microsoft.com/.default&client_secret=',body('Get_Client_Secret_from_Key_Vault')?['value'],'&grant_type=client_credentials')"
          }
        },
        "Parse_JSON": {
          "runAfter": {
            "HTTP": [
