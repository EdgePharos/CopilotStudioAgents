                }
              }
            }
          }
        },
        "HTTP_2": {
          "runAfter": {
            "Parse_JSON": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "5364ba8d-40f3-42d9-83af-023569e5b5e7"
          },
          "type": "Http",
          "inputs": {
            "uri": "@concat(\u0027https://graph.microsoft.com/v1.0/users?$search=\u0022displayName:\u0027,triggerBody()?[\u0027text\u0027],\u0027\u0022\u0026$select=displayName,userPrincipalName,mail,jobTitle,department,accountEnabled\u0027)",
            "method": "GET",
            "headers": {
              "Authorization": "Bearer @{body(\u0027Parse_JSON\u0027)?[\u0027access_token\u0027]}",
              "ConsistencyLevel": "eventual"
            }
          }
        },
        "Respond_to_Copilot": {
